# === piper-moveit 핀 (재현성) — 네이티브 ROS 2 Jazzy 셋업 ===
# docker 시절 원본(이미지 좌표·BASE_IMAGE digest·direct 프로파일 DDS 블록 포함)은
# legacy/docker/versions.env 에 그대로 보관돼 있다. 여기 루트본은 네이티브에서 실제로
# 쓰이는 값만 남긴 축소판이다.
#   - setup-native.sh  : 아래 두 SHA 를 로드/검증하고 pyAgxArm 을 그 SHA 로 checkout
#   - run-mock.sh / run-real.sh : ARM_TYPE/EFFECTOR_TYPE/CAN_IFACE/CAN_BITRATE 런타임 기본값
#   - README 재현성 표 : 두 SHA 를 인용

# AgileX 핀 (릴리스 태그 없음 → commit SHA 고정)
# AGX_ARM_ROS_SHA 는 ros2_ws/src/agx_arm_ros 서브모듈 gitlink 과 일치해야 하는 사람이 읽는 기록
# (.gitmodules 는 branch=ros2 로 floating 이라, 실제 핀은 이 값 + 서브모듈 gitlink).
AGX_ARM_ROS_SHA=e649916179f19b29fdcfbe00b23a54afbc1c024d
PYAGXARM_SHA=a226840db0c3d5c5dc7f3ec78d6cef1a6800f9e6

# 런타임 기본값 (런치 인자 / CAN)
ARM_TYPE=piper
EFFECTOR_TYPE=agx_gripper
CAN_IFACE=can0
CAN_BITRATE=1000000
