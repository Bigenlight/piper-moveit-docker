# === Piper MoveIt Docker — 핀 버전 (재현성) ===
# 이미지 좌표
OWNER=Bigenlight               # GitHub 계정. 로컬 빌드는 OWNER 무관. GHCR pull 시에만 사용.
IMAGE_NAME=piper-moveit
IMAGE_TAG=jazzy
# 로컬: piper-moveit:jazzy   /   GHCR: ghcr.io/${OWNER}/${IMAGE_NAME}:${IMAGE_TAG}

# 베이스 (Tiryoh noVNC ROS2 Jazzy 데스크탑). digest 핀 = 재현성 보장(:jazzy 태그는 시간 지나면 갱신됨).
# 이 digest는 multi-arch 인덱스 매니페스트라 amd64/arm64 둘 다 동일하게 동작.
# 태그로 되돌리려면: BASE_IMAGE=ghcr.io/tiryoh/ros2-desktop-vnc:jazzy
BASE_IMAGE=ghcr.io/tiryoh/ros2-desktop-vnc:jazzy@sha256:0a5fc748ec422a3d293341e0ecbce27bd3d3d20a7b9dad01b28bdefe2ba76e0b

# AgileX 핀 (릴리스 태그 없음 → commit SHA 고정)
AGX_ARM_ROS_SHA=e649916179f19b29fdcfbe00b23a54afbc1c024d
PYAGXARM_SHA=a226840db0c3d5c5dc7f3ec78d6cef1a6800f9e6

# 런타임 기본값
ARM_TYPE=piper
EFFECTOR_TYPE=agx_gripper
CAN_IFACE=can0
CAN_BITRATE=1000000
NOVNC_PORT=6080

# DDS / ROS 그래프 (host 프로파일에서 호스트<->컨테이너 직접 통신용. 다른 프로파일도 이 기본값 사용)
# ※ ros-app.conf 가 %(ENV_X)s 로 참조하므로 이 세 값은 모든 프로파일에서 반드시 존재해야 함(없으면 supervisord 가 ros-app 기동 실패).
ROS_DOMAIN_ID=0                        # 격리 프로파일 기본값. direct 프로파일은 compose 에서 42 로 override(헬퍼와 일치).
RMW_IMPLEMENTATION=rmw_fastrtps_cpp    # Jazzy 기본 RMW(Fast DDS). 호스트 ros2 와 RMW 가 일치해야 통신됨.
FASTDDS_BUILTIN_TRANSPORTS=DEFAULT     # 격리 프로파일(mock/real/dev/gpu) 기본. direct 프로파일만 UDPv4 로 override.
# direct 프로파일(호스트<->컨테이너 bridge discovery)용. 다른 프로파일은 빈값/기본이라 무영향.
ROS_STATIC_PEERS=                      # 유니캐스트 discovery peer. direct 는 compose 에서 게이트웨이 IP 로 override.
ROS_AUTOMATIC_DISCOVERY_RANGE=SUBNET   # Jazzy discovery 범위. static-peer 가 서브넷 너머 붙도록 SUBNET 유지.
